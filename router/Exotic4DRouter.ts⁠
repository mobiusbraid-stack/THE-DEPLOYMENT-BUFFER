     */
    public lift3DToExotic4D(path3D: LegendrianCoordinate[]): Spatial4DCoordinate[] {
        return path3D.map((coord, index) => {
            // Compute the exotic smoothness value 'w' based on boundary slope parity
            // w acts as the handle attachment thickness along the knot projection
            const harmonicFactor = Math.sin(index * this.SYSTEM_CLOCK);
            const exoticW = (coord.y * coord.x) + (harmonicFactor * this.DALETH_COEFFICIENT);

            return {
                x: coord.x,
                y: coord.y,
                z: coord.z,
                w: exoticW
            };
        });
    }

